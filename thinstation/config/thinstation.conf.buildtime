KEYBOARD_MAP=en_us
TIME_ZONE=Australia/Sydney

NET_USE_DHCP=On

AUTOSTART=On
ICONMODE=MANUAL
ALWAYS_ENTER_SERVER=Off
ALLOW_EXIT=Off

SESSION_0_TITLE="Aurora VNC"
SESSION_0_TYPE=vncviewer
SESSION_0_AUTOSTART=FULLSCREEN
SESSION_0_VNCVIEWER_SERVER=server.lan:1
SESSION_0_VNCVIEWER_OPTIONS="-FullScreen"
